{
  "name": "lan-beamdrop",
  "version": "1.0.0",
  "description": "LAN BeamDrop - 局域网文件互传 + 剪切板共享工具",
  "main": "server.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-mac-x64",
      "node18-linux-x64"
    ]
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest",
    "build": "pkg . --out-path dist"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "qrcode-terminal": "^0.12.0"
  },
  "keywords": [
    "lan",
    "file-transfer",
    "clipboard",
    "harmonyos"
  ],
  "license": "MIT",
  "devDependencies": {
    "jest": "^30.4.2",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2"
  }
}
